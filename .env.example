## Environment variables for PaymentApp_Project
## Copy this file to .env and fill in your own values.
## IMPORTANT: Never commit .env to GitHub.

# Flutterwave keys
FLUTTERWAVE_PUBLIC_KEY="PASTE_YOUR_FLUTTERWAVE_PUBLIC_KEY_HERE"
FLUTTERWAVE_SECRET_KEY="PASTE_YOUR_FLUTTERWAVE_SECRET_KEY_HERE"

# Simple dashboard admin token (used to approve pending payments)
ADMIN_TOKEN="CHOOSE_A_STRONG_TOKEN"

# App settings
PORT=8080
BASE_CURRENCY=RWF

# Optional: SQLite DB path (defaults to ./payments.db)
# DB_PATH="/absolute/or/relative/path/to/payments.db"

